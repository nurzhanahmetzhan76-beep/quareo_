# RetailPool AI v2.0 — API Server
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright's Chromium browser + system dependencies (needed for /api/scan)
RUN playwright install --with-deps chromium

COPY retailpool/ retailpool/
COPY frontend/ frontend/
COPY alembic/ alembic/
COPY alembic.ini .

EXPOSE 8000

CMD ["sh", "-c", "alembic upgrade head && uvicorn retailpool.main:app --host 0.0.0.0 --port 8000"]
