# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── Security (MVP static API key) ────────────────────────
API_KEY=change-me-in-production

# ── JWT Authentication ────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Proxy Provider ────────────────────────────────────────
PROXY_PROVIDER_API_URL=
PROXY_PROVIDER_API_KEY=
PROXY_COUNTRY=kz
PROXY_URL=

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=
BOT_API_BASE_URL=http://localhost:8000

# ── Success Fee ───────────────────────────────────────────
SUCCESS_FEE_PERCENT=3.0

# ── Scraper ───────────────────────────────────────────────
SCRAPER_MIN_DELAY=2.0
SCRAPER_MAX_DELAY=5.0
SCRAPER_HEADLESS=true

# ── NKT (National Catalog) API ───────────────────────────
NKT_API_KEY=your-nkt-api-key-here
NKT_API_BASE_URL=https://api.nationalcatalog.kz/v1

# ── Data Encryption ───────────────────────────────────────
ENCRYPTION_KEY=generate-with-python-cryptography-fernet
